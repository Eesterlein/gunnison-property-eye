# Database
POSTGRES_DB=property_eye
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5433/property_eye

# Google Earth Engine
# Service account email from GEE project
GEE_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
# Path to service account JSON key file (never commit this file)
GEE_KEY_FILE=./secrets/gee-key.json

# Auth
JWT_SECRET=your-random-secret-here

# App
ENVIRONMENT=development

# Frontend (Vite)
# tipg has CORS enabled so the frontend hits it directly
VITE_TIPG_URL=http://localhost:8002/api
# ENVIRONMENT=production
